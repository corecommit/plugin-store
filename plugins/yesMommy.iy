local isPlaying: boolean = false
local function pickRandomTrack(trackName: string?)
	if isPlaying then
		return
	end

	if not trackName or not mommyCfg.audioDatabase[trackName] then
		local availableTrackNames = {}
		for name, _ in mommyCfg.audioDatabase do
			availableTrackNames[#availableTrackNames + 1] = name
		end
		if #availableTrackNames == 0 then
			return
		end
		trackName = availableTrackNames[math.random(1, #availableTrackNames)]
	end

	local trackDescription = mommyCfg.audioDatabase[trackName]
	if not trackDescription or #trackDescription.tracks == 0 then
		return
	end

	local randomTrackIndex = math.random(1, #trackDescription.tracks)
	local sound = audioHandler.new(trackName)
	if sound then
		isPlaying = true
		sound.Ended:Connect(function()
			isPlaying = false
		end)
		audioHandler.playSegment(sound, trackName, randomTrackIndex)
	end
end

-- local comfortAudio = audioHandler.new("comfort")
-- local caringAudio = audioHandler.new("caring")
-- local complimentAudio = audioHandler.new("compliment")

local activeConnections = {}
local function mommyRandomHandler(state: boolean)
	if not state then
		for _, conn in activeConnections do
			-- print(conn)
			conn:Disconnect()
		end

		activeConnections = {}
		return
	end

	local humanoid = localPlayer.Character:WaitForChild("Humanoid")
	-- print("GOT HUMANOID", humanoid)

	-- health down or up
	local previousHealth = humanoid.Health
	local lastDamageTime = 0
	local DEBOUNCE_TIME = 2
	table.insert(
		activeConnections,
		humanoid.HealthChanged:Connect(function()
			local currentHealth = humanoid.Health
			local currentTime = tick()

			-- print(currentHealth, currentTime - lastDamageTime)

			if currentTime - lastDamageTime < DEBOUNCE_TIME or currentHealth >= previousHealth then
				previousHealth = currentHealth
				return
			end

			-- print("PLAYING SOUND NOW")
			lastDamageTime = currentTime
			previousHealth = currentHealth
			pickRandomTrack()
			return
		end)
	)

	-- died
	-- print("WAITING FOR DIE")
	table.insert(
		activeConnections,
		humanoid.Died:Connect(function()
			-- print("HUMANOID DIED!!")
			pickRandomTrack("comfort")

			task.defer(function()
				mommyRandomHandler(false)
				localPlayer.CharacterAdded:Wait()
				task.wait(0.1)
				mommyRandomHandler(true)
			end)
		end)
	)
end

configHandler("init")

if mommyCfg.options.onRandom then
	mommyRandomHandler(true)
end

local Plugin = {
	["PluginName"] = "yesMommy",
	["PluginDescription"] = "mommy asmr as a plugin (MAAAP)",
	["Commands"] = {
		["playasmr"] = {
			["ListName"] = "playasmr [kind?] [trackIndex?]",
			["Description"] = "mommy's here!",
			["Aliases"] = {},
			["Function"] = function(args, speaker)
				local kindName = args[1] or "comfort"
				local trackIndex = tonumber(args[2]) or 1
				local isPreferMambo = mommyCfg.options.preferMambo

				local audio = loadedAudio[kindName .. (isPreferMambo and "_matikanetannhauser" or "_normal")]
					or audioHandler.new(kindName)
				local createdAudio = audioHandler.playSegment(audio, kindName, trackIndex)

				if not createdAudio then
					notify("yesMommy.playasmr", "failed to play audio with playaudio cmd")
				end
			end,
		},
		["mommyCredit"] = {
			["ListName"] = "mommyCredit",
			["Description"] = "displays credits for the asmr creator(s) used in this plugin, with links",
			["Aliases"] = {},
			["Function"] = function(args, speaker)
				local credits = (function()
					local result = {}
					for artist, url in pairs(mommyCfg.credits) do
						result[#result + 1] = artist .. " - " .. url[1]
					end
					return table.concat(result, "\n")
				end)()
				print(credits)
				notify("yesMommy.credit", "credit to: (open devtool for full info) " .. credits)
			end,
		},
		["mommyRandom"] = {
			["ListName"] = "mommyRandom [boolean?]",
			["Description"] = "randomly plays mommy asmr based on game's event",
			["Aliases"] = {},
			["Function"] = function(args, speaker)
				local newVal = (args[1] == "true" and true or false) or not mommyCfg.options.onRandom
				configHandler("edit", { "options", "onRandom" }, newVal)
				mommyRandomHandler(newVal)
				notify("yesMommy.random", "onRandom set to " .. tostring(mommyCfg.options.onRandom))
			end,
		},
		["mommyVolume"] = {
			["ListName"] = "mommyVolume [number]",
			["Description"] = "set the volume of the asmr player",
			["Aliases"] = { "volume", "vol" },
			["Function"] = function(args, speaker)
				local volume = tonumber(args[1])
				if not volume then
					notify("yesMommy.volume", "invalid volume")
					return
				end
				configHandler("edit", { "options", "volume" }, volume)
				notify("yesMommy.volume", "mommyVolume set to " .. tostring(mommyCfg.options.volume))
			end,
		},
		["mommyMambo"] = {
			["ListName"] = "mommyMambo [boolean?]",
			["Description"] = "prefer matikanetannhauser's vocal style over normal asmr",
			["Aliases"] = { "mamboVoice", "wantMambo", "prefermambo" },
			["Function"] = function(args, speaker)
				configHandler(
					"edit",
					{ "options", "preferMambo" },
					(args[1] == "true" and true or false) or not mommyCfg.options.preferMambo
				)

				notify(
					"yesMommy.mommyMambo",
					"preferMambo set to "
						.. tostring(mommyCfg.options.preferMambo)
						.. (mommyCfg.options.preferMambo and " (good choice!!!!)" or " ...awww")
				)
			end,
		},
		-- ["addTrack"] = {
		-- 	["ListName"] = "addTrack [name] [url] [json]",
		-- 	["Description"] = "add a new asmr track - name url(must end .mp3) json(optional audiodesc)",
		-- 	["Aliases"] = { "addTrack", "addasmr" },
		-- 	["Function"] = function(args, speaker)
		-- 		addTrack(args, speaker)
		-- 	end,
		-- },
		-- ["removeTrack"] = {
		-- 	["ListName"] = "removeTrack [name]",
		-- 	["Description"] = "remove asmr track",
		-- 	["Aliases"] = { "removetrack", "removeasmr" },
		-- 	["Function"] = function(args, speaker)
		-- 		removeTrack(args[1])
		-- 	end,
		-- },
	},
}

return Plugin
