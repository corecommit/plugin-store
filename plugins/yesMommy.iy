-- init: configHandler("init")
-- edit preferMambo: configHandler("edit", {"options", "preferMambo"}, true)
local function configHandler(type: "init" | "edit", keyPath: { string? }, value: any?)
	-- print(httpService:JSONEncode(mommyCfg))
	local success, _ = pcall(function()
		if type == "init" then
			if not isfile(baseAudioLocation .. "/cfg.json") then
				notify("yesMommy.init", "init from start, plse wait...")
				writefile(baseAudioLocation .. "/cfg.json", httpService:JSONEncode(mommyCfg))
			end
			local ok, parsed = pcall(httpService.JSONDecode, httpService, readfile(baseAudioLocation .. "/cfg.json"))

			if ok and validateMommyCfg(parsed) then
				mommyCfg = parsed
			else
				notify("yesMommy.init", "cfg.json is corupted, rw to default")
				writefile(baseAudioLocation .. "/cfg.json", httpService:JSONEncode(mommyCfg))
			end
		end

		if type == "edit" then
			if #keyPath == 0 and not value then
				return false
			end

			local cfg = mommyCfg
			for i = 1, #keyPath - 1 do
				cfg = cfg[keyPath[i]]
			end

			cfg[keyPath[#keyPath]] = value

			writefile(baseAudioLocation .. "/cfg.json", httpService:JSONEncode(mommyCfg))
		end
	end)

	-- print(httpService:JSONEncode(mommyCfg))
	return success
end

local function fetchAudio(audioName: string, url: string?): string | false
	local filePath = baseAudioLocation .. "/" .. audioName

	if isfile(filePath) then
		return getcustomasset(filePath)
	else
		notify("yesMommy.fetchAudio", "no cached hit for " .. audioName .. ", fetching")

		local fetchUrl = url or mommyCfg.audioDatabase[audioName][1]

		if not fetchUrl then
			warn("failed to download " .. audioName .. ": no cached hit and no url provided")
			return false
		end

		-- print(fetchUrl)
		local response = request({
			Url = fetchUrl,
			Method = "GET",
		})

		if not response.Success then
			warn("failed to download " .. audioName .. ": " .. response.StatusCode)
			return false
		end

		writefile(filePath, response.Body)
		return getcustomasset(filePath)
	end
end

local audioHandler = {}

function audioHandler.new(trackName: string): Sound | false
	local audioDescription = mommyCfg.audioDatabase[trackName]
	if not audioDescription then
		return false
	end

	local cacheKey = trackName .. (mommyCfg.options.preferMambo and "_matikanetannhauser" or "_normal")

	if loadedAudio[cacheKey] then
		return loadedAudio[cacheKey]
	end

	local fileIndex = mommyCfg.options.preferMambo and 2 or 1
	local asset =
		fetchAudio(audioDescription.filename[fileIndex], audioDescription.url and audioDescription.url[fileIndex])
	if not asset then
		notify("yesMommy.audioHandler.new", "failed to pull " .. audioDescription.filename[fileIndex])
		return false
	end

	local sound = Instance.new("Sound")
	sound.SoundId = asset
	sound.Volume = mommyCfg.options.volume
	sound.Parent = soundContainer
	sound.Name = randomString()

	loadedAudio[cacheKey] = sound
	return sound
end

function audioHandler.playSegment(audio: Sound, trackName: string, index: number): boolean
	local sound = audio

	if not sound then
		warn("yesMommy: failed to play segment of " .. trackName)
		return false
	end

	sound.Volume = mommyCfg.options.volume

	local desc = mommyCfg.audioDatabase[trackName]
	local track = desc and desc.tracks[index]
	if not track then
		warn("yesMommy: no track " .. tostring(index) .. " in " .. trackName)
		return false
	end

	print("playSegment", track.subtitle, track.start, track.finish)

	sound.PlaybackRegion = NumberRange.new(track.start, track.finish)
	sound.PlaybackRegionsEnabled = true
	sound.PlaybackRegion = NumberRange.new(track.start, track.finish)
	sound:Play()

	notify("yesMommy.subtitle", track.subtitle or "", (track.finish - track.start) + 2)

	return true
end

