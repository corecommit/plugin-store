local mommyCfg: MommyCfg = {
	version = 1,
	audioDatabase = builtInAudios,
	options = {
		preferMambo = false,
		volume = 1,
		onRandom = false,
	},
	credits = {
		["youtube @ mae asmr"] = { "https://www.youtube.com/watch?v=eBjHneKNgrY" },
	},
}

local function validateMommyCfg(cfg): boolean
	if type(cfg) ~= "table" then
		return false
	end
	if type(cfg.version) ~= "number" then
		return false
	end
	if type(cfg.audioDatabase) ~= "table" then
		return false
	end
	if type(cfg.options) ~= "table" then
		return false
	end
	if type(cfg.options.preferMambo) ~= "boolean" then
		return false
	end
	if type(cfg.options.volume) ~= "number" then
		return false
	end
	if type(cfg.credits) ~= "table" then
		return false
	end
	return true
end

