if
	(not isfolder or not makefolder or not getcustomasset)
	or (
		not type(isfolder) == "function"
		or not type(makefolder) == "function"
		or not type(getcustomassets) == "function"
	)
then
	notify("yesMommy", "required apis failed, pls change yur executor")
	return
end

local httpService = game:GetService("HttpService")
local localPlayer = game:GetService("Players").LocalPlayer

local baseAudioLocation = "yesMommyASMRSounds"
-- local cdnAudio = "https://share.valhalladev.org/raw"

local loadedAudio = {}

if not isfolder(baseAudioLocation) then
	makefolder(baseAudioLocation)
end

local soundContainer = Instance.new("Folder")
soundContainer.Name = "yesMommyAudios"
soundContainer.Parent = game:GetService("SoundService")

type AudioTrack = {
	subtitle: string,
	start: number,
	finish: number,
}

type AudioDesc = {
	filename: { string },
	url: { string },
	tracks: { AudioTrack },
}

type AudioDatabase = {
	[string]: AudioDesc,
}

type MommyCfg = {
	version: number,
	audioDatabase: AudioDatabase,
	options: {
		preferMambo: boolean,
		volume: number,
		onRandom: boolean | number,
	},
	credits: {
		[string]: { string },
	},
}

